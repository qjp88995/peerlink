# Traefik 对外端口（避开 8888-8893）
TRAEFIK_PORT=8894
TRAEFIK_DASHBOARD_PORT=8895

# 宿主用户（Linux 下建议设为 `id -u` / `id -g` 以对齐 bind-mount 权限）
UID=1000
GID=1000

# 信令服务公网加固（均可选，留空则用内置默认）
# 浏览器 Origin 白名单（逗号分隔）；公网部署应显式设置以拒绝跨站连接
ALLOWED_ORIGINS=
# 单条信令消息最大字节数（默认 1MB）
MAX_PAYLOAD_BYTES=1048576
# 心跳间隔毫秒，连续两周期无 pong 即回收僵尸连接（默认 30s）
HEARTBEAT_INTERVAL_MS=30000
# 单连接建房限流（create-room / lan-invite）：突发上限与补满窗口（默认 10 次 / 60s）
ROOM_CREATE_BURST=10
ROOM_CREATE_WINDOW_MS=60000

# WebRTC ICE 服务器（前端用；逗号分隔多个 STUN）
VITE_STUN_URLS=stun:stun.l.google.com:19302
# 可选 TURN（留空则仅用 STUN）
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
