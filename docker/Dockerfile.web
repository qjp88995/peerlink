# ─────────────────────────────────────────────────────────────
# Web 生产镜像。Vite 构建静态产物 → nginx 提供，并把 /signal 反代到
# signaling 服务（带 WebSocket Upgrade 头）。
# ─────────────────────────────────────────────────────────────
FROM node:24-bookworm-slim AS base
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate

FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json ./
COPY packages/protocol/package.json packages/protocol/
COPY apps/signaling/package.json apps/signaling/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile

FROM base AS build
WORKDIR /app
COPY --from=deps /app ./
COPY packages/protocol/ packages/protocol/
COPY apps/web/ apps/web/
# ICE 配置走运行时注入（见下方 entrypoint），构建期无需任何 VITE_* 参数。
# web 无需预构建 protocol：vite 经 exports 的 import 条件直接打包其 TS 源码。
RUN pnpm --filter @peerlink/web build

FROM nginx:alpine
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
# 启动时按容器环境变量（STUN_URLS / TURN_*）生成运行时 ICE 配置，无需重建镜像。
COPY docker/40-peerlink-ice-config.sh /docker-entrypoint.d/40-peerlink-ice-config.sh
RUN chmod +x /docker-entrypoint.d/40-peerlink-ice-config.sh
EXPOSE 80
# busybox wget 自带于 nginx:alpine；探活根路径（SPA index.html）。
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1/ || exit 1
